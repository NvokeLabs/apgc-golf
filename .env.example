# Database connection string
DATABASE_URI=mongodb://127.0.0.1/your-database-name

# Or use a PG connection string
#DATABASE_URI=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

# Xendit Payment Gateway
XENDIT_SECRET_KEY=YOUR_XENDIT_SECRET_KEY
XENDIT_PUBLIC_KEY=YOUR_XENDIT_PUBLIC_KEY
XENDIT_WEBHOOK_TOKEN=YOUR_XENDIT_WEBHOOK_TOKEN

# Resend Email Service
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=noreply@polinemagolf.com

# Supabase Storage (S3-compatible)
SUPABASE_STORAGE_ENDPOINT=https://YOUR_PROJECT.storage.supabase.co/storage/v1/s3
SUPABASE_STORAGE_REGION=YOUR_REGION
SUPABASE_STORAGE_ACCESS_KEY=YOUR_S3_ACCESS_KEY
SUPABASE_STORAGE_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
# Public media bucket (general uploads)
SUPABASE_STORAGE_BUCKET_NAME=YOUR_PUBLIC_BUCKET
# Private bucket for payment-transfer proofs (Story 0) — access-controlled,
# NOT publicly readable. Must be a separate, non-public bucket.
SUPABASE_STORAGE_PROOFS_BUCKET=YOUR_PRIVATE_PROOFS_BUCKET

# Manual-transfer upload tokens (Story 3) — HMAC secret for signed upload links.
# Separate from PAYLOAD_SECRET so it can be rotated without invalidating sessions.
UPLOAD_TOKEN_SECRET=YOUR_UPLOAD_TOKEN_SECRET

# Base URL for callbacks and links
BASE_URL=http://localhost:3000
