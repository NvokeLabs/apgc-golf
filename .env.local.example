# Local development env template — copy to `.env.local` and fill the values
# printed by `supabase start`. `.env.local` is gitignored (keep secrets out of git).
#
#   cp .env.local.example .env.local
#   supabase start        # copy the S3 Access Key / Secret Key / URLs it prints
#
# Next.js loads `.env.local` ahead of `.env`, so this points the app at the
# LOCAL Supabase stack instead of the shared cloud project.

# --- Database (local Supabase Postgres, DIRECT connection — no pgbouncer) ---
# Note: local uses port 54322 and a direct connection. Do NOT add ?pgbouncer=true.
DATABASE_URI=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Payload ---
PAYLOAD_SECRET=local-dev-payload-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# --- Manual-transfer upload tokens (Story 3) ---
# Dedicated secret, separate from PAYLOAD_SECRET so it can be rotated alone.
UPLOAD_TOKEN_SECRET=local-dev-upload-token-secret

# --- Supabase Storage (local S3 protocol endpoint, port 54321) ---
# Fill ACCESS_KEY / SECRET from the "S3 Access Key" / "S3 Secret Key" that
# `supabase start` prints.
SUPABASE_STORAGE_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_STORAGE_REGION=local
SUPABASE_STORAGE_ACCESS_KEY=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
# Public media bucket (general uploads)
SUPABASE_STORAGE_BUCKET_NAME=golf
# Private proofs bucket (Story 0)
SUPABASE_STORAGE_PROOFS_BUCKET=proofs

# --- Email (optional locally; leave blank to no-op, or use a real Resend key) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
